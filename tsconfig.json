{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "typeRoots": ["./types", "./node_modules/@types"]
  },
	"include": ["types/**/*.d.ts", "extensions/**/*.ts", "test/**/*.ts"]
}
