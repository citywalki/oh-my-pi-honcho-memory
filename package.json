{
  "name": "@fa-software/oh-my-pi-honcho-memory",
  "version": "0.1.7",
  "type": "module",
  "description": "Honcho multi-developer memory extension for oh-my-pi",
  "license": "MIT",
  "author": "citywalki",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/citywalki/oh-my-pi-honcho-memory.git"
  },
  "bugs": {
    "url": "https://github.com/citywalki/oh-my-pi-honcho-memory/issues"
  },
  "homepage": "https://github.com/citywalki/oh-my-pi-honcho-memory#readme",
  "keywords": [
    "oh-my-pi",
    "honcho",
    "memory",
    "extension",
    "ai",
    "agent"
  ],
  "main": "./dist/index.js",
  "types": "./dist/extensions/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "README_CN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun build ./extensions/index.ts --outdir ./dist --target bun --external @oh-my-pi/pi-coding-agent && tsc --emitDeclarationOnly",
    "check": "tsc --noEmit",
    "release": "npm version",
    "prepublishOnly": "bun run clean && bun run build",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@honcho-ai/sdk": "^2.1.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.9",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "omp": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
